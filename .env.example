# Notion Configuration
# Replace with your actual internal integration token
NOTION_TOKEN=secret_your_notion_token_here

# Replace with your actual Notion database ID (32 characters)
NOTION_DB_ID=34e173006daf81d38d92c53194799ead

# NextAuth Configuration
# Run `npx auth secret` or use `openssl rand -base64 33` to generate a secret
AUTH_SECRET=your_auth_secret_here

# Authentication Whitelist
# Comma-separated list of allowed email addresses
ALLOWED_EMAILS=your.email@example.com,another@example.com

# GitHub OAuth (Optional: Setup at https://github.com/settings/apps)
AUTH_GITHUB_ID=your_github_client_id
AUTH_GITHUB_SECRET=your_github_client_secret

# Google OAuth (Optional: Setup at https://console.cloud.google.com/)
AUTH_GOOGLE_ID=your_google_client_id
AUTH_GOOGLE_SECRET=your_google_client_secret
